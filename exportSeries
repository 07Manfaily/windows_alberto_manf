// ── TRANSFORMATIONS ───────────────────────────────────────────────────────────
const aggregateByMonth = (data) => {
  const map = {};
  (data||[]).forEach(d => {
    const k = d.month||"??";
    if (!map[k]) map[k] = { month:k, presentiel:0, e_learning:0, classe_virtuelle:0, multimodal:0, total:0 };
    map[k].presentiel       += d.presentiel||0;
    map[k].e_learning       += d.e_learning||0;
    map[k].classe_virtuelle += d.classe_virtuelle||0;
    map[k].multimodal       += d.multimodal||0;
    map[k].total            += d.total||0;
  });
  return Object.values(map).sort((a,b)=>a.month.localeCompare(b.month))
    .map(d => ({ ...d, label: MONTH_NAMES[d.month?.slice(5)] || d.month }));
};

const aggregateByModalite = (data) => {
  const t = { Présentiel:0,"E-learning":0,"Cl. Virtuelle":0,Multimodal:0 };
  (data||[]).forEach(d => {
    t["Présentiel"]     += d.presentiel||0;
    t["E-learning"]     += d.e_learning||0;
    t["Cl. Virtuelle"]  += d.classe_virtuelle||0;
    t["Multimodal"]     += d.multimodal||0;
  });
  return Object.entries(t).map(([name,value]) => ({ name, value }));
};

const fmt = (n) => {
  if (n===undefined||n===null) return "—";
  if (n>=1_000_000) return `${(n/1_000_000).toFixed(1)}M`;
  if (n>=1_000)     return `${(n/1_000).toFixed(0)}k`;
  return String(n);
};

const fmtFCFA = (n) => {
  if (!n) return "—";
  if (n>=1_000_000) return `${(n/1_000_000).toFixed(2)}M FCFA`;
  return `${(n/1_000).toFixed(0)}k FCFA`;
};

