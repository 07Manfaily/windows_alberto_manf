// ── HELPERS ───────────────────────────────────────────────────────────────────
const fmt = (n) => {
  if (n===undefined||n===null) return "—";
  if (n>=1_000_000) return `${(n/1_000_000).toFixed(2)}M`;
  if (n>=1_000)     return `${(n/1_000).toFixed(0)}k`;
  return String(Math.round(n));
};
const fmtFCFA = (n) => n ? `${fmt(n)} FCFA` : "—";

const aggregateCollabByMonth = (data) => {
  const map = {};
  (data||[]).forEach(d => {
    const k = d.month||"??";
    if (!map[k]) map[k] = { month:k, presentiel:0, e_learning:0, classe_virtuelle:0, multimodal:0, total:0 };
    map[k].presentiel       += d.presentiel||0;
    map[k].e_learning       += d.e_learning||0;
    map[k].classe_virtuelle += d.classe_virtuelle||0;
    map[k].multimodal       += d.multimodal||0;
    map[k].total            += d.total||0;
  });
  return Object.values(map).sort((a,b)=>a.month.localeCompare(b.month))
    .map(d => ({ ...d, label: MONTH_STR[d.month?.slice(5)] || d.month }));
};

const aggregateCollabByModalite = (data) => {
  const t = { Présentiel:0, "E-learning":0, "Cl. Virtuelle":0, Multimodal:0 };
  (data||[]).forEach(d => {
    t["Présentiel"]    += d.presentiel||0;
    t["E-learning"]    += d.e_learning||0;
    t["Cl. Virtuelle"] += d.classe_virtuelle||0;
    t["Multimodal"]    += d.multimodal||0;
  });
  return Object.entries(t).map(([name,value]) => ({ name, value }));
};

// Transformer /collab/forme/genre → pivot par sexe/mois
const pivotGenre = (data) => {
  const map = {};
  (data||[]).forEach(d => {
    const k = d.mois_num;
    if (!map[k]) map[k] = { mois_num:k, label:MONTH_FR[k]||`M${k}`, Masculin:0, Feminin:0 };
    if (d.sexe==="Masculin")  map[k].Masculin  += d.nombre_de_collaborateurs_forme||0;
    else                       map[k].Feminin   += d.nombre_de_collaborateurs_forme||0;
  });
  return Object.values(map).sort((a,b)=>a.mois_num-b.mois_num);
};

// Pie genre global depuis /collab/forme/genre
const pieGenre = (data) => {
  const t = { Masculin:0, Feminin:0 };
  (data||[]).forEach(d => {
    if (d.sexe==="Masculin") t.Masculin += d.nombre_de_collaborateurs_forme||0;
    else                      t.Feminin  += d.nombre_de_collaborateurs_forme||0;
  });
  return Object.entries(t).map(([name,value]) => ({ name, value }));
};

// ── AXIOS HOOK ──────────────────────────────────────────────────────────────
const useAxios = (url) => {
  const [data,    setData]    = useState(null);
  const [loading, setLoading] = useState(false);
  const [error,   setError]   = useState(null);
  const [ts,      setTs]      = useState(null);

  const run = useCallback(async () => {
    setLoading(true); setError(null);
    try {
      const { data: json } = await axios.get(url);
      setData(json.data || json);
      setTs(new Date().toLocaleTimeString("fr-FR"));
    } catch(e) {
      const msg = e.response
        ? `HTTP ${e.response.status} — ${e.response.statusText || "Erreur serveur"}`
        : e.message || "Erreur réseau";
      setError(msg);
    } finally { setLoading(false); }
  }, [url]);

  useEffect(() => { run(); }, [run]);
  return { data, loading, error, refetch:run, ts };
};

