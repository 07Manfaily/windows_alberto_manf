                      <YAxis domain={[0,100]} tick={{ fill:C.textMute,fontSize:10 }} axisLine={false} tickLine={false}/>
                      <Tooltip content={<Tip />}/>
                      <Bar dataKey="p" name="Taux %" radius={[5,5,0,0]}>
                        {FAKE_ELEARNING_GROUPES.map(d=><Cell key={d.groupe} fill={d.p>=85?"url(#gNavy)":"url(#gRed)"}/>)}
                      </Bar>
                    </BarChart>
                  </ResponsiveContainer>
                </Box>

                {/* Participants par type */}
                <Box title="Participants par type de formation" accent={C.navy}>
                  <ResponsiveContainer width="100%" height={210}>
                    <BarChart data={FAKE_PARTICIPANTS_TYPE} barSize={14}>
                      <CartesianGrid strokeDasharray="3 3" stroke={C.border} vertical={false}/>
                      <XAxis dataKey="type" tick={{ fill:C.textMid,fontSize:9 }} axisLine={false} tickLine={false}/>
                      <YAxis tick={{ fill:C.textMute,fontSize:9 }} axisLine={false} tickLine={false}/>
                      <Tooltip content={<Tip />}/>
                      <Bar dataKey="participants" name="Participants"   fill={C.red}  radius={[3,3,0,0]}/>
                      <Bar dataKey="collab"       name="Collaborateurs" fill={C.navy} radius={[3,3,0,0]}/>
                    </BarChart>
                  </ResponsiveContainer>
                </Box>

                {/* Coûts par OGF pie */}
                <Box title="Répartition des coûts par OGF" accent={C.gold}>
                  <ResponsiveContainer width="100%" height={210}>
                    <PieChart>
                      <Pie data={FAKE_FORMATIONS_OGF} cx="50%" cy="50%" outerRadius={72} dataKey="cout" nameKey="ogf" paddingAngle={3}
                        label={({ogf,percent})=>`${ogf} ${(percent*100).toFixed(0)}%`} labelLine={{ stroke:C.borderMid }}>
                        {[C.red,C.navy,C.gold,C.navyLight,"#7B000D"].map((col,i)=><Cell key={i} fill={col} stroke="white" strokeWidth={2}/>)}
                      </Pie>
                      <Tooltip content={<Tip />}/>
                    </PieChart>
                  </ResponsiveContainer>
                </Box>
              </div>
            </div>
          </div>
        )}

        {/* ══════════════ SECTION 04 – REPORTING ══════════════ */}
        {show("reporting") && (
          <div>
            <SectionTitle num="04" color={C.red}>Reporting formation &amp; Types de programme</SectionTitle>
            <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:14 }}>
              <Box title="Indicateurs de performance — Radar" accent={C.navy}>
                <ResponsiveContainer width="100%" height={280}>
                  <RadarChart data={FAKE_REPORTING}>
                    <defs>
                      <linearGradient id="radarFill" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stopColor={C.navy} stopOpacity={0.25}/>
                        <stop offset="100%" stopColor={C.red} stopOpacity={0.1}/>
                      </linearGradient>
                    </defs>
                    <PolarGrid stroke={C.border}/>
                    <PolarAngleAxis dataKey="subject" tick={{ fill:C.textMid,fontSize:11,fontFamily:"'Trebuchet MS'" }}/>
                    <Radar name="Score" dataKey="A" stroke={C.navy} fill="url(#radarFill)" strokeWidth={2.5}/>
                    <Tooltip content={<Tip />}/>
                    <Legend wrapperStyle={{ fontSize:10,color:C.textMid }}/>
                  </RadarChart>
                </ResponsiveContainer>
              </Box>

              <Box title="Type de programme de formation" accent={C.red}>
                <ResponsiveContainer width="100%" height={180}>
                  <PieChart>
                    <Pie data={FAKE_PROGRAMME} cx="50%" cy="50%" innerRadius={44} outerRadius={70} dataKey="value" nameKey="name" paddingAngle={4}
                      label={({name,value})=>`${name} ${value}%`} labelLine={{ stroke:C.borderMid }}>
                      {[C.navy,C.red,C.navyLight,C.gold].map((col,i)=><Cell key={i} fill={col} stroke="white" strokeWidth={2}/>)}
                    </Pie>
                    <Tooltip content={<Tip />}/>
                  </PieChart>
                </ResponsiveContainer>
                <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginTop:12 }}>
                  {FAKE_PROGRAMME.map((d,i)=>{
                    const cols=[C.navy,C.red,C.navyLight,C.gold];
                    return (
                      <div key={i} style={{ background:`${cols[i]}08`,border:`1.5px solid ${cols[i]}25`,borderLeft:`4px solid ${cols[i]}`,borderRadius:8,padding:"8px 12px",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
                        <span style={{ color:C.textMid,fontSize:10,fontFamily:"'Trebuchet MS'" }}>{d.name}</span>
                        <span style={{ color:cols[i],fontSize:16,fontWeight:800,fontFamily:"Georgia" }}>{d.value}%</span>
                      </div>
                    );
                  })}
                </div>
              </Box>
            </div>
          </div>
        )}

        {/* FOOTER */}
        <div style={{ borderTop:`2px solid ${C.border}`,paddingTop:16,display:"flex",justifyContent:"space-between",alignItems:"center" }}>
          <div style={{ display:"flex",alignItems:"center",gap:8 }}>
            <div style={{ display:"flex",borderRadius:3,overflow:"hidden" }}>
              <div style={{ background:C.red,width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center" }}>
                <span style={{ color:"white",fontSize:5,fontWeight:900,fontFamily:"'Trebuchet MS'" }}>SG</span>
              </div>
              <div style={{ background:C.navy,width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center" }}>
                <span style={{ color:"white",fontSize:5,fontWeight:800,fontFamily:"'Trebuchet MS'" }}>CI</span>
              </div>
            </div>
            <span style={{ color:C.textMute,fontSize:9,fontFamily:"'Trebuchet MS'",letterSpacing:1 }}>SGCI · DRH · Données de démonstration — structure API réelle</span>
          </div>
          <div style={{ display:"flex",alignItems:"center",gap:6 }}>
            <div style={{ height:2,width:24,background:`linear-gradient(90deg,${C.navy},${C.red})`,borderRadius:1 }}/>
            <span style={{ color:C.textMute,fontSize:9,fontFamily:"'Trebuchet MS'",letterSpacing:1.5 }}>TABLEAU DE BORD · {new Date().getFullYear()}</span>
          </div>
        </div>
      </div>

      <style>{`
        @keyframes spin  { to { transform: rotate(360deg); } }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
      `}</style>
    </div>
  );
}
