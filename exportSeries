                <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginTop:12 }}>
                  {FAKE_PROGRAMME.map((d,i)=>{
                    const cols=[C.navy,C.red,C.navyLight,C.gold];
                    return (
                      <div key={i} style={{ background:`${cols[i]}08`,border:`1.5px solid ${cols[i]}25`,borderLeft:`4px solid ${cols[i]}`,borderRadius:8,padding:"8px 12px",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
                        <span style={{ color:C.textMid,fontSize:10,fontFamily:"'Trebuchet MS'" }}>{d.name}</span>
                        <span style={{ color:cols[i],fontSize:16,fontWeight:800,fontFamily:"Georgia" }}>{d.value}%</span>
                      </div>
                    );
                  })}
                </div>
              </Box>
            </div>
          </div>
        )}

        {/* FOOTER */}
        <div style={{ borderTop:`2px solid ${C.border}`,paddingTop:14,display:"flex",justifyContent:"space-between",alignItems:"center" }}>
          <div style={{ display:"flex",alignItems:"center",gap:8 }}>
            <div style={{ display:"flex",borderRadius:3,overflow:"hidden" }}>
              <div style={{ background:C.red,width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center" }}><span style={{ color:"white",fontSize:5,fontWeight:900,fontFamily:"'Trebuchet MS'" }}>SG</span></div>
              <div style={{ background:C.navy,width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center" }}><span style={{ color:"white",fontSize:5,fontWeight:800,fontFamily:"'Trebuchet MS'" }}>CI</span></div>
            </div>
            <span style={{ color:C.textMute,fontSize:8,fontFamily:"'Trebuchet MS'",letterSpacing:1 }}>SGCI · DRH · APIs réelles : collab/modalite · budget/formation · investissement · mode/distribution · collab/genre</span>
          </div>
          <div style={{ display:"flex",alignItems:"center",gap:6 }}>
            <div style={{ height:2,width:20,background:`linear-gradient(90deg,${C.navy},${C.red})`,borderRadius:1 }}/>
            <span style={{ color:C.textMute,fontSize:8,fontFamily:"'Trebuchet MS'",letterSpacing:1.5 }}>TABLEAU DE BORD · {new Date().getFullYear()}</span>
          </div>
        </div>
      </div>

      <style>{`
        @keyframes spin  { to { transform: rotate(360deg); } }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
      `}</style>
    </div>
  );
}
